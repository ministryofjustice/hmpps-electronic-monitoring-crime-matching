{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "noEmit": false,
    "allowJs": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "typeRoots": ["./node_modules/@types"],
    "strict": true,
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "assets/**/*.ts",
    "integration_tests",
    "dist",
    "cypress.config.ts",
    "esbuild",
    "eslint.config.mjs"
  ],
  "include": ["**/*.js", "**/*.ts"]
}
